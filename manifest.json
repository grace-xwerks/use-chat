{
  "manifest_version": 3,
  "name": "Use Chat",
  "version": "1.1.0",
  "description": "Reminds Grace Engineering teammates to use Google Chat instead of internal email.",
  "homepage_url": "https://github.com/grace-xwerks/use-chat",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
